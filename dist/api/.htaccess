Options -Indexes
RewriteEngine On

# Pasar el header Authorization a PHP (Apache lo bloquea por defecto)
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

# Denegar acceso directo a archivos sensibles
<FilesMatch "^(db\.php|setup\.sql)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
